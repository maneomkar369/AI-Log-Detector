# ── Database ──
DATABASE_URL=postgresql+asyncpg://admin:strong_password@localhost:5432/anomaly_detection
# For development without PostgreSQL, use SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./anomaly_detection.db

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Edge Server ──
EDGE_SERVER_HOST=0.0.0.0
EDGE_SERVER_PORT=8000

# ── Anomaly Detection Thresholds ──
ANOMALY_K_VALUE=3.0
EMA_LEARNING_RATE=0.05
CUSUM_THRESHOLD=5.0
BASELINE_DAYS=7
DATA_RETENTION_DAYS=30

# ── Rule-based Threat Intel ──
# Comma-separated package names and domains that should trigger immediate alerts.
# Keep empty by default to avoid test/fake IOC alerts.
# Example:
# MALICIOUS_APPS=com.real.malware.pkg,com.other.bad.pkg
# MALICIOUS_DOMAINS=bad-domain.tld,phish-domain.tld
MALICIOUS_APPS=
MALICIOUS_DOMAINS=
RULE_ALERT_COOLDOWN_SECONDS=120
# Ignore synthetic/test sources from alerting pipeline.
IGNORED_ALERT_DEVICE_IDS=ioc_test_device
IGNORED_ALERT_DEVICE_PREFIXES=test_device_,ioc_test_
IGNORED_ALERT_PACKAGES=com.bad.malware

# ── NGROK ──
NGROK_AUTH_TOKEN=your_ngrok_auth_token
NGROK_DOMAIN=your-domain.ngrok.io

# ── FCM Push Notifications (optional) ──
FCM_SERVER_KEY=your_fcm_server_key

# ── Dashboard ──
DASHBOARD_SECRET_KEY=change-me-to-a-random-secret
DASHBOARD_PORT=5000

# ── Container -> Host ADB Bridge ──
# Default (Docker Desktop/macOS/Windows): tcp:host.docker.internal:5037
# Linux fallback (recommended when host.docker.internal is unreachable):
# ADB_SERVER_SOCKET=tcp:192.168.1.5:5037
ADB_SERVER_SOCKET=tcp:host.docker.internal:5037

# ── Dashboard CSP ──
# Keep false unless a third-party script absolutely requires string evaluation.
DASHBOARD_CSP_ALLOW_UNSAFE_EVAL=false
